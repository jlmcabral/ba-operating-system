{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [".github/copilot-instructions.md", "AGENTS.md"],
  "skills": {
    "paths": ["skills"]
  },
  "agent": {
    "archivist": {
      "description": "Manage Confluence wiki content — create pages, apply labels, audit consistency, and follow the documentation taxonomy",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "prompt": "{file:./agents/wiki-content.md}"
    }
  },
  "mcp": {
    "mcp-atlassian": {
      "type": "local",
      "command": [
        "docker",
        "run",
        "-i",
        "--rm",
        "-e",
        "CONFLUENCE_URL",
        "-e",
        "CONFLUENCE_USERNAME",
        "-e",
        "CONFLUENCE_PERSONAL_TOKEN",
        "-e",
        "JIRA_URL",
        "-e",
        "JIRA_USERNAME",
        "-e",
        "JIRA_PERSONAL_TOKEN",
        "ghcr.io/sooperset/mcp-atlassian:latest"
      ],
      "enabled": true
    }
  }
}
